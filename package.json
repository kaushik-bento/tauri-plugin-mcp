{
  "name": "@bento/automate-tauri-desktop-app",
  "version": "0.2.0",
  "author": "Bento",
  "description": "",
  "type": "module",
  "types": "./dist-js/index.d.ts",
  "main": "./dist-js/index.cjs",
  "module": "./dist-js/index.js",
  "exports": {
    "types": "./dist-js/index.d.ts",
    "import": "./dist-js/index.js",
    "require": "./dist-js/index.cjs"
  },
  "files": [
    "dist-js",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "build-plugin": "cargo build --release",
    "build:server": "cd mcp-server-ts && pnpm i && pnpm build",
    "build:all": "pnpm build && pnpm build-plugin && pnpm build:server",
    "clean": "rm -rf node_modules dist-js target mcp-server-ts/node_modules mcp-server-ts/dist",
    "prepublishOnly": "pnpm build",
    "pretest": "pnpm build"
  },
  "dependencies": {
    "@tauri-apps/api": ">=2.2.0"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^11.1.6",
    "rollup": "^4.9.6",
    "typescript": "^5.3.3",
    "tslib": "^2.6.2"
  }
}
